# ============================================================
# AI Monitor - Production Environment Configuration
# Copy this to /opt/monitor/.env and fill in your values
# chmod 600 /opt/monitor/.env
# ============================================================

# ===== Database =====
# SQLite (default, single-server)
AIMONITOR_DATABASE_URL=sqlite+aiosqlite:///opt/monitor/ai_monitor/store/ai_monitor.db
# PostgreSQL (production, multi-server) - uncomment and install asyncpg
# AIMONITOR_DATABASE_URL=postgresql+asyncpg://monitor:password@localhost:5432/ai_monitor

# ===== AI Provider =====
AIMONITOR_AI_PROVIDER=openai
AIMONITOR_OPENAI_API_KEY=sk-your-real-key-here
AIMONITOR_OPENAI_API_BASE=https://api.openai.com/v1
AIMONITOR_OPENAI_MODEL=gpt-4o-mini

# ===== GitHub / Gitee Tokens =====
AIMONITOR_GITHUB_TOKEN=ghp_your-github-token
AIMONITOR_GITEE_TOKEN=

# ===== Notification Channels =====
AIMONITOR_FEISHU_WEBHOOK_URL=
AIMONITOR_FEISHU_APP_ID=
AIMONITOR_FEISHU_APP_SECRET=
AIMONITOR_DINGTALK_WEBHOOK_URL=
AIMONITOR_WECHAT_WORK_WEBHOOK_URL=
AIMONITOR_SLACK_WEBHOOK_URL=
AIMONITOR_DISCORD_WEBHOOK_URL=

# Email (SMTP)
AIMONITOR_EMAIL_SMTP_HOST=smtp.example.com
AIMONITOR_EMAIL_SMTP_PORT=587
AIMONITOR_EMAIL_FROM=monitor@example.com
AIMONITOR_EMAIL_USERNAME=monitor@example.com
AIMONITOR_EMAIL_PASSWORD=

# ===== Dashboard =====
AIMONITOR_DASHBOARD_HOST=127.0.0.1
AIMONITOR_DASHBOARD_PORT=8081
AIMONITOR_DASHBOARD_SECRET_KEY=change-me-in-production
AIMONITOR_DASHBOARD_CORS_ORIGINS=https://your-domain.com
