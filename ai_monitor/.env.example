# AI Monitor Configuration
# Copy this file to .env and fill in your values

# ==================== Database ====================
AIMONITOR_DATABASE_URL=sqlite+aiosqlite:///ai_monitor/store/ai_monitor.db

# ==================== AI Provider ====================
AIMONITOR_AI_PROVIDER=openai
AIMONITOR_OPENAI_API_KEY=sk-your-key-here
AIMONITOR_OPENAI_API_BASE=https://api.openai.com/v1
AIMONITOR_OPENAI_MODEL=gpt-4o-mini

# ==================== Notification ====================
# Email
AIMONITOR_EMAIL_SMTP_HOST=smtp.example.com
AIMONITOR_EMAIL_SMTP_PORT=587
AIMONITOR_EMAIL_FROM=monitor@example.com
AIMONITOR_EMAIL_USERNAME=monitor@example.com
AIMONITOR_EMAIL_PASSWORD=your-password

# SMS (Alibaba Cloud)
AIMONITOR_SMS_ACCESS_KEY_ID=
AIMONITOR_SMS_ACCESS_KEY_SECRET=
AIMONITOR_SMS_SIGN_NAME=
AIMONITOR_SMS_TEMPLATE_CODE=
AIMONITOR_SMS_PHONE_NUMBERS=13800138000

# DingTalk
AIMONITOR_DINGTALK_WEBHOOK_URL=

# Feishu
AIMONITOR_FEISHU_WEBHOOK_URL=

# WeChat Work
AIMONITOR_WECHAT_WORK_WEBHOOK_URL=

# Slack
AIMONITOR_SLACK_WEBHOOK_URL=

# Discord
AIMONITOR_DISCORD_WEBHOOK_URL=

# Generic Webhook
AIMONITOR_WEBHOOK_URL=
AIMONITOR_WEBHOOK_SECRET=

# ==================== Repository watch (GitHub / Gitee) ====================
AIMONITOR_GITHUB_TOKEN=
AIMONITOR_GITEE_TOKEN=
# Poll interval for watch-repo daemon (seconds, default 3600 = 1 hour)
AIMONITOR_REPO_WATCH_INTERVAL_SECONDS=3600

# ==================== Dashboard ====================
AIMONITOR_DASHBOARD_SECRET_KEY=change-me-in-production
